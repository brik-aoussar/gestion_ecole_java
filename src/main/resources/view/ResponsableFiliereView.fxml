<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.ResponsableFiliereCtrl">
    <top>
        <HBox style="-fx-background-color:#117A65; -fx-padding:10 16;"
              spacing="12" alignment="CENTER_LEFT">
            <Label text="🏫 Responsable Filière"
                   style="-fx-text-fill:white; -fx-font-size:15; -fx-font-weight:bold;"/>
            <Label fx:id="lblFiliere" style="-fx-text-fill:#A9DFBF; -fx-font-size:12;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblStatut" style="-fx-text-fill:#BDC3C7; -fx-font-size:11;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding:12;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Promotion :"/>
                <ComboBox fx:id="cbPromotion" prefWidth="200"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnVoirResultats" text="📊 Résultats"
                        onAction="#handleConsulterResultats"/>
                <Button fx:id="btnValiderNotes" text="✔ Valider les notes"
                        onAction="#handleValiderNotes"
                        style="-fx-background-color:#117A65; -fx-text-fill:white; -fx-font-weight:bold;"/>
            </HBox>
            <TableView fx:id="tableEtudiants" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCne"    text="CNE"    prefWidth="130"/>
                    <TableColumn fx:id="colNom"    text="Nom"    prefWidth="160"/>
                    <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="160"/>
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>

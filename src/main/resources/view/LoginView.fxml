<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.LoginController"
      alignment="CENTER" spacing="16"
      style="-fx-background-color:#2C3E50; -fx-padding:40;">

    <Label text="🎓 Gestion des Notes"
           style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:white;"/>
    <Label text="Académie — Accès sécurisé"
           style="-fx-font-size:12; -fx-text-fill:#BDC3C7;"/>

    <VBox spacing="10" maxWidth="300" style="-fx-background-color:white;
          -fx-background-radius:8; -fx-padding:24;">

        <TextField fx:id="txtLogin" promptText="Login"
                   style="-fx-font-size:13;"/>
        <PasswordField fx:id="txtPassword" promptText="Mot de passe"
                       style="-fx-font-size:13;"/>

        <Label fx:id="lblErreur" wrapText="true"
               style="-fx-text-fill:#E74C3C; -fx-font-size:11;"/>

        <Button fx:id="btnConnexion" text="Se connecter" maxWidth="Infinity"
                onAction="#handleLogin"
                style="-fx-background-color:#2980B9; -fx-text-fill:white;
                       -fx-font-weight:bold; -fx-padding:8 0;"/>

        <ProgressIndicator fx:id="progress" maxHeight="30"
                           visible="false" managed="false"/>
    </VBox>
</VBox>

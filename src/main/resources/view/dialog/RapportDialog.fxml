<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" style="-fx-padding: 15;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.RapportDialogCtrl">

    <Label fx:id="lblResume" style="-fx-font-weight: bold; -fx-font-size: 13;"/>

    <TableView fx:id="tableRapport" VBox.vgrow="ALWAYS" prefHeight="400">
        <columns>
            <TableColumn fx:id="colRang"     text="Rang"     prefWidth="60"/>
            <TableColumn fx:id="colEtudiant" text="Etudiant" prefWidth="200"/>
            <TableColumn fx:id="colMoyenne"  text="Moyenne"  prefWidth="80"/>
            <TableColumn fx:id="colMention"  text="Mention"  prefWidth="100"/>
            <TableColumn fx:id="colStatut"   text="Statut"   prefWidth="80"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button fx:id="btnExportPDF" text="Exporter PDF" onAction="#handleExportPDF"
                style="-fx-background-color:#2196F3;-fx-text-fill:white;" prefWidth="130"/>
        <Button text="Fermer" onAction="#handleFermer" prefWidth="100"/>
    </HBox>

</VBox>

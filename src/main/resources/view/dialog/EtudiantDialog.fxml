<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.EtudiantDialogCtrl">

    <Label text="CNE"/>
    <TextField fx:id="txtCne" promptText="CNE etudiant"/>

    <Label text="Nom"/>
    <TextField fx:id="txtNom" promptText="Nom"/>

    <Label text="Prenom"/>
    <TextField fx:id="txtPrenom" promptText="Prenom"/>

    <Label text="Email"/>
    <TextField fx:id="txtEmail" promptText="Email"/>

    <Label text="Telephone"/>
    <TextField fx:id="txtTelephone" promptText="Telephone"/>

    <Label text="Date de naissance"/>
    <DatePicker fx:id="dpDateNaissance"/>

    <Label fx:id="lblErreur" style="-fx-text-fill: red;" visible="false"/>

    <HBox spacing="10">
        <Button fx:id="btnSauvegarder" text="Sauvegarder" onAction="#handleSauvegarder"
                style="-fx-background-color:#2196F3;-fx-text-fill:white;" prefWidth="120"/>
        <Button fx:id="btnAnnuler" text="Annuler" prefWidth="100"/>
    </HBox>

</VBox>
